# ==========================================
# FasoCare - Global Environment Configuration
# ==========================================

# Environment
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Database (used by docker-compose)
DB_USERNAME=fasocare
DB_PASSWORD=change_me_in_production
DB_DATABASE=fasocare_db

# JWT (min 32 characters for production)
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_min_32_chars_here

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_SMS_FROM=FasoCare

# SSL Certificates (for production)
SSL_CERT_PATH=./nginx/ssl/cert.pem
SSL_KEY_PATH=./nginx/ssl/key.pem
