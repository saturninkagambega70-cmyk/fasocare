# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
ENABLE_SWAGGER=true

# Security
# Must be at least 32 chars
JWT_SECRET=fasocare-dev-jwt-secret-32-chars-min-2026
JWT_REFRESH_SECRET=fasocare-dev-refresh-secret-32-char-2026
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
ENCRYPTION_KEY=fasocare-dev-encryption-key-32-char-2026

# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=fasocare
DB_PASSWORD=fasocare_password
DB_DATABASE=fasocare_db
DB_SSL=false
USE_SYNC=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Rate limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=20

# Feature flags
ENABLE_AUTO_VERIFICATION=false
ENABLE_SMS_NOTIFICATIONS=true

# Telecom
AT_API_KEY=
AT_USERNAME=
AT_SMS_FROM=FasoCare
TWILIO_API_KEY=
TWILIO_API_SECRET=
