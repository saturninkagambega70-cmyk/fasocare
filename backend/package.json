{
  "name": "fasocare-core-api",
  "version": "1.0.0",
  "description": "Infrastructure Nationale de Santé du Burkina Faso - Core API Service",
  "main": "dist/main.js",
  "author": "Agence Numérique de Santé (ANS)",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:week5": "jest --runInBand src/ussd/ussd.service.spec.ts src/telecom/otp.service.spec.ts",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d src/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/data-source.ts"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/testing": "^11.1.17",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.21",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "africastalking": "^0.7.9",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto-js": "^4.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jest": "^30.3.0",
    "joi": "^18.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/pdfkit": "^0.17.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0"
  }
}
