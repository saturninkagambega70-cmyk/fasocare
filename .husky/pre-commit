#!/bin/sh

# Pre-commit hook for FasoCare
# Runs linting and tests before committing

set -e

echo "🔍 Running pre-commit checks..."

# Lint and format
echo "📝 Linting code..."
npm run lint --if-present || echo "Lint check skipped (lint script not found)"

# Run backend tests
echo "🧪 Running backend tests..."
cd backend
npm run test --if-present || echo "Tests skipped (test script not found)"
cd ..

echo "✅ Pre-commit checks passed!"
